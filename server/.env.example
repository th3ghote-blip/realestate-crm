DATABASE_URL="postgresql://postgres:postgres@localhost:5432/realestate_crm?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=4000

# Domain used to mint per-agent inbound email addresses (e.g. agent-<uuid>@inbound.yourapp.com)
APP_INBOUND_DOMAIN="inbound.yourapp.com"

# Comma-separated origins allowed by CORS
CORS_ORIGIN="http://localhost:5173"

# Optional: outbound email via SendGrid. Without these, outbound messages are
# stored as logged_only and not sent.
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""
